{
  "name": "dialer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/init-db-simple.js && node server.js",
    "dev:server": "node server.js",
    "dev:next": "next dev --turbopack",
    "build": "next build",
    "start": "node scripts/init-db-simple.js && node server.js",
    "start:next": "node scripts/init-db-simple.js && next start",
    "lint": "eslint",
    "db:sync": "npx sequelize-cli db:migrate",
    "db:reset": "npx sequelize-cli db:migrate:undo:all && npx sequelize-cli db:migrate",
    "db:test": "npx sequelize-cli db:migrate:status",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all",
    "postbuild": "echo 'Build completed successfully'"
  },
  "dependencies": {
    "@tiptap/extension-color": "^3.27.1",
    "@tiptap/extension-font-family": "^3.27.1",
    "@tiptap/extension-font-size": "^3.0.0-next.3",
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@twilio/voice-sdk": "^2.18.2",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.5",
    "next": "16.2.1",
    "otpauth": "^9.5.1",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-redux": "^9.2.0",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "twilio": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/qrcode": "^1.5.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "sequelize-cli": "^6.6.3",
    "tailwindcss": "^4"
  }
}
